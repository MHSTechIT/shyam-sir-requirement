# PostgreSQL connection (matches docker-compose.yml defaults)
DATABASE_URL="postgresql://orgchart:orgchart@localhost:5432/orgchart?schema=public"

# API port
PORT=4000

# Where uploaded role-clarity documents are stored on disk
UPLOAD_DIR=./uploads

# CORS origin for the dev frontend (Vite). Use * to allow all.
CLIENT_ORIGIN=http://localhost:5173

# Optional: set a value to gate the whole app behind one shared password.
# Leave empty/unset for a fully open chart (the chosen default).
SHARED_PASSWORD=
