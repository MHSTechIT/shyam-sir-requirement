# PostgreSQL connection
DATABASE_URL="postgresql://postgres:password@localhost:5432/nsi_team?schema=public"

# API port
PORT=4000

# Uploaded documents are stored inside PostgreSQL (files.data) — no disk needed.

# CORS origin for the dev frontend (Vite). Use * to allow all.
CLIENT_ORIGIN=http://localhost:5173

# Optional: set a value to gate the whole app behind one shared password.
# Leave empty/unset for a fully open chart (the chosen default).
SHARED_PASSWORD=
